    },
    {
      "technicalName": "RV_CURR_YEAR_JAN",
      "label": "당년1월(hidden)",
      "type": "LOOKUP",
      "hidden": true,
      "lookupSource": "V_MONTH_COMPARISON",
      "lookupMeasure": "CURRENT_YEAR_JAN",
      "inputVariableRef": "P_MONTH"
    },
    {
      "technicalName": "RV_PREVIOUS_YEAR_SAME_MONTH",
      "label": "전년동월(hidden)",
      "type": "LOOKUP",
      "hidden": true,
      "lookupSource": "V_MONTH_COMPARISON",
      "lookupMeasure": "PREVIOUS_YEAR_SAME_MONTH",
      "inputVariableRef": "P_MONTH"
    },
    {
      "technicalName": "RV_PREVIOUS_YEAR_JAN",
      "label": "전년1월(hidden)",
      "type": "LOOKUP",
      "hidden": true,
      "lookupSource": "V_MONTH_COMPARISON",
      "lookupMeasure": "PREVIOUS_YEAR_JAN",
      "inputVariableRef": "P_MONTH"
    }
  ]
