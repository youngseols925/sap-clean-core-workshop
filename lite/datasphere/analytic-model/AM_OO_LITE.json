      "label": "오더수량",
      "measureType": "BASE",
      "factSourceRef": "V_OO_LITE_F",
      "factSourceMeasureRef": "ORD_QTY"
    },
    {
      "technicalName": "CURR_MONTH_AMT",
      "label": "당월 오더금액",
      "measureType": "RESTRICTED",
      "baseMeasureRef": "ORD_AMT",
      "restrictedBy": [
        {
          "dimensionRef": "AUDAT_YM",
          "operator": "EQ",
          "variableRef": "RV_CURR_MONTH"
        }
      ]
    },
    {
      "technicalName": "PREV_MONTH_AMT",
      "label": "전월 오더금액",
      "measureType": "RESTRICTED",
      "baseMeasureRef": "ORD_AMT",
      "restrictedBy": [
        {
          "dimensionRef": "AUDAT_YM",
          "operator": "EQ",
          "variableRef": "RV_PREVIOUS_MONTH"
        }
      ]
    },
    {
      "technicalName": "CURR_YTD_AMT",
      "label": "당년누계 오더금액",
      "measureType": "RESTRICTED",
      "baseMeasureRef": "ORD_AMT",
      "restrictedBy": [
        {
          "dimensionRef": "AUDAT_YM",
          "operator": "BT",
          "variableRef": "RV_CURR_YEAR_JAN",
          "variableRef2": "RV_CURR_MONTH"
        }
      ]
    },
    {
      "technicalName": "PREV_YTD_AMT",
      "label": "전년누계 오더금액",
      "measureType": "RESTRICTED",
      "baseMeasureRef": "ORD_AMT",
      "restrictedBy": [
        {
          "dimensionRef": "AUDAT_YM",
          "operator": "BT",
          "variableRef": "RV_PREVIOUS_YEAR_JAN",
          "variableRef2": "RV_PREVIOUS_YEAR_SAME_MONTH"
        }
      ]
    }
  ],
  "variables": [
    {
      "technicalName": "P_MONTH",
      "label": "기준월(YYYYMM)",
      "type": "INPUT",
      "mandatory": true,
      "dataType": "String",
      "length": 6
    },
    {
      "technicalName": "RV_CURR_MONTH",
      "label": "당월(hidden)",
      "type": "LOOKUP",
      "hidden": true,
      "lookupSource": "V_MONTH_COMPARISON",
      "lookupMeasure": "CURRENT_MONTH",
      "inputVariableRef": "P_MONTH"
    },
    {
      "technicalName": "RV_PREVIOUS_MONTH",
      "label": "전월(hidden)",
      "type": "LOOKUP",
      "hidden": true,
